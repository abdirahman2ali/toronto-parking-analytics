# Neon PostgreSQL — pooled connection (application reads/writes)
TORONTO_DATABASE_URL=postgresql://user:pass@ep-xxx.pooler.region.neon.tech/toronto_parking

# Neon PostgreSQL — direct connection (DDL/migrations only)
TORONTO_DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.region.neon.tech/toronto_parking

# dbt connection components (parsed from TORONTO_DATABASE_URL for local dbt runs)
TORONTO_PGHOST=ep-xxx.pooler.region.neon.tech
TORONTO_PGPORT=5432
TORONTO_PGDATABASE=toronto_parking
TORONTO_PGUSER=user
TORONTO_PGPASSWORD=pass
